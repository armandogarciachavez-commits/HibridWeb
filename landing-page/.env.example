# ═══════════════════════════════════════════
# HYBRID TRAINING — Variables de entorno
# Copia este archivo como .env y llena los valores
# ═══════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:3000

# ── STRIPE (https://dashboard.stripe.com) ─
# Usa claves TEST para pruebas, LIVE para producción
STRIPE_SECRET_KEY=sk_test_REEMPLAZA_AQUI
STRIPE_PUBLIC_KEY=pk_test_REEMPLAZA_AQUI
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZA_AQUI

# ── MERCADOPAGO (https://www.mercadopago.com.mx/developers) ──
# Access Token: Panel MP > Tus integraciones > Credenciales
MP_ACCESS_TOKEN=APP_USR-REEMPLAZA_AQUI

# ── EMAIL PARA FORMULARIO DE CONTACTO ─────
# Con Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuemail@gmail.com
SMTP_PASS=contraseña_de_aplicacion_gmail
CONTACT_EMAIL=tuemail@gmail.com

# ── RECAPTCHA ─────────────────────────────
# Regístrate en https://www.google.com/recaptcha/admin
# y reemplaza la data-sitekey en index.html con tu Site Key real
RECAPTCHA_SECRET_KEY=REEMPLAZA_AQUI
